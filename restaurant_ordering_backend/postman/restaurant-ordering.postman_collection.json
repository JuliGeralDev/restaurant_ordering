{
  "info": {
    "_postman_id": "9a7d7f38-93f8-4c6d-a8b2-restaurant-ordering",
    "name": "Restaurant Ordering Local API",
    "description": "Local Postman collection for the Restaurant Ordering backend. This project does not implement authentication; it uses a fixed development user by default.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
