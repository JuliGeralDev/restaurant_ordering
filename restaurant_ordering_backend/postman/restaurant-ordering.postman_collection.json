      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Idempotency-Key",
            "value": "{{idempotencyKey}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"userId\": \"{{userId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/orders",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "orders"
          ]
        },
        "description": "Repeats the same checkout request using the same idempotency key to verify idempotent behavior."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code remains 202 for idempotent replay', function () {",
              "  pm.response.to.have.status(202);",
              "});",
              "",
              "const response = pm.response.json();",
              "pm.test('Returned orderId matches stored orderId', function () {",
              "  pm.expect(response.orderId).to.eql(pm.collectionVariables.get('orderId'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "11. Get Order Timeline",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/orders/{{orderId}}/timeline?pageSize=10",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "orders",
            "{{orderId}}",
            "timeline"
          ],
          "query": [
            {
              "key": "pageSize",
              "value": "10"
            }
          ]
        },
        "description": "Retrieves timeline events for the stored orderId."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const timeline = pm.response.json();",
              "if (timeline && timeline.nextToken) {",
              "  pm.collectionVariables.set('nextToken', timeline.nextToken);",
              "} else {",
              "  pm.collectionVariables.unset('nextToken');",
              "}"
            ]
          }
        }
      ]
    },
