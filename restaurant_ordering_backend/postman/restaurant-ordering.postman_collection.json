  "item": [
    {
      "name": "1. Get Menu",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/menu",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "menu"
          ]
        },
        "description": "Retrieves seeded menu products. Product 1 is a simple burger and product 8 is a custom burger with modifiers."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const menu = pm.response.json();",
              "pm.test('Menu is an array', function () {",
              "  pm.expect(Array.isArray(menu)).to.eql(true);",
              "});",
              "",
              "if (Array.isArray(menu) && menu.length > 0) {",
              "  const simple = menu.find((item) => item.productId === '1') || menu[0];",
              "  const custom = menu.find((item) => item.productId === '8') || menu.find((item) => item.modifiers);",
              "  if (simple) pm.collectionVariables.set('productId', simple.productId);",
              "  if (custom) pm.collectionVariables.set('customProductId', custom.productId);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Add Simple Item To Cart",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/cart/items",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "cart",
            "items"
          ]
        },
        "description": "Creates a new order if needed and adds a simple seeded menu product."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const data = pm.response.json();",
              "pm.collectionVariables.set('orderId', data.orderId);",
              "if (Array.isArray(data.items) && data.items.length > 0) {",
              "  const item = data.items.find((entry) => entry.productId === pm.collectionVariables.get('productId')) || data.items[0];",
              "  if (item && item.cartItemId) pm.collectionVariables.set('cartItemId', item.cartItemId);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "3. Add Custom Item To Cart",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"userId\": \"{{userId}}\",\n  \"productId\": \"{{customProductId}}\",\n  \"quantity\": 1,\n  \"modifiers\": [\n    {\n      \"groupId\": \"protein\",\n      \"optionId\": \"beef\",\n      \"name\": \"Beef Patty\",\n      \"price\": 0\n    },\n    {\n      \"groupId\": \"toppings\",\n      \"optionId\": \"cheese\",\n      \"name\": \"Cheddar Cheese\",\n      \"price\": 500\n    },\n    {\n      \"groupId\": \"sauces\",\n      \"optionId\": \"bbq\",\n      \"name\": \"BBQ Sauce\",\n      \"price\": 400\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/cart/items",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "cart",
            "items"
          ]
        },
        "description": "Adds a customizable product using valid seeded modifiers."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const data = pm.response.json();",
              "pm.collectionVariables.set('orderId', data.orderId);",
              "if (Array.isArray(data.items)) {",
              "  const customItem = data.items.find((entry) => entry.productId === pm.collectionVariables.get('customProductId'));",
              "  if (customItem && customItem.cartItemId) pm.collectionVariables.set('customCartItemId', customItem.cartItemId);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "4. Get Order By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/orders/{{orderId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "orders",
            "{{orderId}}"
          ]
        },
        "description": "Fetches the current order details using the stored orderId."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const order = pm.response.json();",
              "if (Array.isArray(order.items)) {",
              "  const simpleItem = order.items.find((entry) => entry.productId === pm.collectionVariables.get('productId'));",
              "  const customItem = order.items.find((entry) => entry.productId === pm.collectionVariables.get('customProductId'));",
              "  if (simpleItem && simpleItem.cartItemId) pm.collectionVariables.set('cartItemId', simpleItem.cartItemId);",
              "  if (customItem && customItem.cartItemId) pm.collectionVariables.set('customCartItemId', customItem.cartItemId);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "5. Update Custom Cart Item",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"userId\": \"{{userId}}\",\n  \"cartItemId\": \"{{customCartItemId}}\",\n  \"quantity\": 2,\n  \"modifiers\": [\n    {\n      \"groupId\": \"protein\",\n      \"optionId\": \"chicken\",\n      \"name\": \"Grilled Chicken\",\n      \"price\": 0\n    },\n    {\n      \"groupId\": \"toppings\",\n      \"optionId\": \"bacon\",\n      \"name\": \"Crispy Bacon\",\n      \"price\": 900\n    },\n    {\n      \"groupId\": \"sauces\",\n      \"optionId\": \"mayo\",\n      \"name\": \"Mayonnaise\",\n      \"price\": 300\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/cart/items",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "cart",
            "items"
          ]
        },
        "description": "Updates a specific cart item instance using its cartItemId."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const order = pm.response.json();",
              "if (Array.isArray(order.items)) {",
              "  const customItem = order.items.find((entry) => entry.cartItemId === pm.collectionVariables.get('customCartItemId')) || order.items.find((entry) => entry.productId === pm.collectionVariables.get('customProductId'));",
              "  if (customItem && customItem.cartItemId) pm.collectionVariables.set('customCartItemId', customItem.cartItemId);",
              "}"
            ]
          }
        }
      ]
    },
